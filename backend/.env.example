# Admin API (tours) — use the same MONGODB_URI as your main app to share one database.
PORT=3010

MONGODB_URI=mongodb://127.0.0.1:27017/traveltours

# Admin UI origin (Vite).
CLIENT_ORIGIN=http://localhost:5173

# Optional: required for POST/PUT and for ?includeDeleted=true on GET in production.
# ADMIN_API_KEY=change-me
